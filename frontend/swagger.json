{
  "openapi": "3.0.4",
  "info": {
    "title": "Blog API",
    "version": "v1"
  },
  "paths": {
    "/api/v1/posts/{id}": {
      "get": {
        "tags": [
          "Post"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Post retrieved successfully.",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/PostDto"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PostDto"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/PostDto"
                }
              }
            }
          },
          "404": {
            "description": "Post not found."
          },
          "500": {
            "description": "Internal server error."
          }
        }
      },
      "put": {
        "tags": [
          "Post"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "allOf": [
                  {
                    "$ref": "#/components/schemas/PostUpdateDto"
                  }
                ]
              }
            },
            "text/json": {
              "schema": {
                "allOf": [
                  {
                    "$ref": "#/components/schemas/PostUpdateDto"
                  }
                ]
              }
            },
            "application/*+json": {
              "schema": {
                "allOf": [
                  {
                    "$ref": "#/components/schemas/PostUpdateDto"
                  }
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Post updated successfully.",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/PostDto"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PostDto"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/PostDto"
                }
              }
            }
          },
          "404": {
            "description": "Post not found."
          },
          "500": {
            "description": "Internal server error."
          }
        }
      },
      "delete": {
        "tags": [
          "Post"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Post deleted successfully."
          },
          "404": {
            "description": "Post not found."
          },
          "500": {
            "description": "Internal server error."
          }
        }
      }
    },
    "/api/v1/posts/page": {
      "get": {
        "tags": [
          "Post"
        ],
        "parameters": [
          {
            "name": "PageIndex",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "PageSize",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "SearchTerm",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Sort",
            "in": "query",
            "description": "JSON array of SortParameter objects",
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/components/schemas/PostSortFieldSortParameter"
              },
              "description": "JSON array of SortParameter objects"
            }
          },
          {
            "name": "Filters",
            "in": "query",
            "description": "JSON array of SortParameter objects",
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/components/schemas/PostFilterFieldFilterParameter"
              },
              "description": "JSON array of SortParameter objects"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Get posts' page retrieved successfully.",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/PostDtoPageDto"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PostDtoPageDto"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/PostDtoPageDto"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error."
          }
        }
      }
    },
    "/api/v1/posts": {
      "post": {
        "tags": [
          "Post"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "allOf": [
                  {
                    "$ref": "#/components/schemas/PostCreateDto"
                  }
                ]
              }
            },
            "text/json": {
              "schema": {
                "allOf": [
                  {
                    "$ref": "#/components/schemas/PostCreateDto"
                  }
                ]
              }
            },
            "application/*+json": {
              "schema": {
                "allOf": [
                  {
                    "$ref": "#/components/schemas/PostCreateDto"
                  }
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Post created successfully.",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/PostDto"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PostDto"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/PostDto"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error."
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "FilterOperator": {
        "enum": [
          "Equals",
          "NotEquals",
          "Contains",
          "GreaterThan",
          "LessThan",
          "GreaterThanOrEqual",
          "LessThanOrEqual",
          "In"
        ],
        "type": "string"
      },
      "OrderBy": {
        "enum": [
          "Asc",
          "Desc"
        ],
        "type": "string"
      },
      "PageDataDto": {
        "type": "object",
        "properties": {
          "pageIndex": {
            "type": "integer",
            "format": "int32"
          },
          "totalPages": {
            "type": "integer",
            "format": "int32"
          },
          "totalCount": {
            "type": "integer",
            "format": "int32"
          },
          "hasPreviousPage": {
            "type": "boolean"
          },
          "hasNextPage": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      },
      "PostCreateDto": {
        "required": [
          "content",
          "title"
        ],
        "type": "object",
        "properties": {
          "title": {
            "minLength": 1,
            "type": "string"
          },
          "content": {
            "minLength": 1,
            "type": "string"
          },
          "slug": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "PostDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "title": {
            "type": "string",
            "nullable": true
          },
          "content": {
            "type": "string",
            "nullable": true
          },
          "slug": {
            "type": "string",
            "nullable": true
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      },
      "PostDtoPageDto": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PostDto"
            },
            "nullable": true
          },
          "pageData": {
            "allOf": [
              {
                "$ref": "#/components/schemas/PageDataDto"
              }
            ],
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "PostFilterField": {
        "enum": [
          "Title",
          "Content",
          "CreatedAt",
          "UpdatedAt"
        ],
        "type": "string"
      },
      "PostFilterFieldFilterParameter": {
        "type": "object",
        "properties": {
          "field": {
            "allOf": [
              {
                "$ref": "#/components/schemas/PostFilterField"
              }
            ]
          },
          "operator": {
            "allOf": [
              {
                "$ref": "#/components/schemas/FilterOperator"
              }
            ]
          },
          "value": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "PostSortField": {
        "enum": [
          "Title",
          "CreatedAt",
          "UpdatedAt"
        ],
        "type": "string"
      },
      "PostSortFieldSortParameter": {
        "type": "object",
        "properties": {
          "field": {
            "allOf": [
              {
                "$ref": "#/components/schemas/PostSortField"
              }
            ]
          },
          "orderBy": {
            "allOf": [
              {
                "$ref": "#/components/schemas/OrderBy"
              }
            ]
          },
          "priority": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "PostUpdateDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "nullable": true
          },
          "content": {
            "type": "string",
            "nullable": true
          },
          "slug": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    }
  },
  "tags": [
    {
      "name": "Post"
    }
  ]
}